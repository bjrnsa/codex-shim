#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done

ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

if [ "$#" -eq 0 ] || [ "${1:-}" = "list" ]; then
  exec uv run --directory "$ROOT" codex-shim model list
fi

exec uv run --directory "$ROOT" codex-shim model use "$1"

